SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://<prod-db-host>:5432/<prod-db-name>?sslmode=require
SPRING_DATASOURCE_USERNAME=<prod-db-user>
SPRING_DATASOURCE_PASSWORD=<prod-db-password>

APP_JWT_SECRET=<prod-jwt-secret-min-32-bytes>
APP_PAYMENT_PROVIDER=razorpay
APP_PAYMENT_RAZORPAY_KEY_ID=<prod-razorpay-key-id>
APP_PAYMENT_RAZORPAY_KEY_SECRET=<prod-razorpay-key-secret>
APP_PAYMENT_WEBHOOK_SECRET=<prod-payment-webhook-secret>
APP_CORS_ALLOWED_ORIGINS=https://app.example.com

# Optional: override storage paths to match container mounts.
CARNALYSYS_STORAGE_AVATAR_DIR=/app/storage/uploads/avatars
CARNALYSYS_STORAGE_VEHICLES_DIR=/app/storage/uploads/vehicles
CARNALYSYS_STORAGE_RECEIPTS_DIR=/app/storage/uploads/receipts
CARNALYSYS_STORAGE_LOGS_DIR=/app/storage/logs
