SPRING_PROFILES_ACTIVE=uat
SERVER_PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://<uat-db-host>:5432/<uat-db-name>
SPRING_DATASOURCE_USERNAME=<uat-db-user>
SPRING_DATASOURCE_PASSWORD=<uat-db-password>

APP_JWT_SECRET=<uat-jwt-secret-min-32-bytes>
APP_PAYMENT_PROVIDER=razorpay
APP_PAYMENT_RAZORPAY_KEY_ID=<uat-razorpay-key-id>
APP_PAYMENT_RAZORPAY_KEY_SECRET=<uat-razorpay-key-secret>
APP_PAYMENT_WEBHOOK_SECRET=<uat-payment-webhook-secret>
APP_CORS_ALLOWED_ORIGINS=https://uat.example.com

FIREBASE_PROJECT_ID=<uat-firebase-project-id>
FIREBASE_CLIENT_EMAIL=<uat-firebase-client-email>
FIREBASE_PRIVATE_KEY=<uat-firebase-private-key>
# Preferred when running with mounted secret file:
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json